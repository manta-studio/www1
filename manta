<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manta Studio | Architecture & Design</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; }
        .project-card:hover img { transform: scale(1.05); transition: all 0.5s ease; }
    </style>
</head>
<body class="bg-white text-gray-900">

    <nav class="flex justify-between items-center px-8 py-6 sticky top-0 bg-white/80 backdrop-blur-md z-50">
        <div class="text-2xl font-semibold tracking-tighter">MANTA STUDIO</div>
        <div class="space-x-8 text-sm uppercase tracking-widest hidden md:block">
            <a href="#projects" class="hover:text-gray-500 transition">Projekty</a>
            <a href="#about" class="hover:text-gray-500 transition">O nas</a>
            <a href="#contact" class="hover:text-gray-500 transition">Kontakt</a>
        </div>
    </nav>

    <header class="h-[80vh] flex items-center px-8 bg-gray-50 border-b border-gray-100">
        <div class="max-w-4xl">
            <h1 class="text-6xl md:text-8xl font-light leading-tight tracking-tight">
                Projektujemy <br><span class="font-semibold italic text-gray-400">przestrzeń jutra.</span>
            </h1>
            <p class="mt-8 text-lg text-gray-500 max-w-lg">
                Manta Studio to multidyscyplinarna pracownia architektoniczna, w której estetyka spotyka się z funkcjonalnością.
            </p>
        </div>
    </header>

    <main id="projects" class="py-20 px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
            
            <div class="project-card overflow-hidden group">
                <div class="bg-gray-200 aspect-[16/9] mb-4 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?auto=format&fit=crop&q=80&w=1200" alt="CP Headquarters" class="w-full h-full object-cover transition duration-500">
                </div>
                <h3 class="text-xl font-medium">CP Headquarters</h3>
                <p class="text-gray-400 text-sm uppercase tracking-wider">Commercial / Office</p>
            </div>

            <div class="project-card overflow-hidden group">
                <div class="bg-gray-200 aspect-[16/9] mb-4 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=1200" alt="D1mension" class="w-full h-full object-cover transition duration-500">
                </div>
                <h3 class="text-xl font-medium">D1mension</h3>
                <p class="text-gray-400 text-sm uppercase tracking-wider">Residential / Luxury</p>
            </div>

            <div class="project-card overflow-hidden group">
                <div class="bg-gray-200 aspect-[16/9] mb-4 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1562774053-701939374585?auto=format&fit=crop&q=80&w=1200" alt="Fulbright University" class="w-full h-full object-cover transition duration-500">
                </div>
                <h3 class="text-xl font-medium">Fulbright University</h3>
                <p class="text-gray-400 text-sm uppercase tracking-wider">Education / Public</p>
            </div>

            <div class="project-card overflow-hidden group">
                <div class="bg-gray-200 aspect-[16/9] mb-4 overflow-hidden">
                    <img src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&q=80&w=1200" alt="Nanee Hotel" class="w-full h-full object-cover transition duration-500">
                </div>
                <h3 class="text-xl font-medium">Nanee Hotel</h3>
                <p class="text-gray-400 text-sm uppercase tracking-wider">Hospitality / Boutique</p>
            </div>

        </div>
    </main>

    <footer id="contact" class="bg-black text-white py-20 px-8">
        <div class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-start">
            <div class="mb-10 md:mb-0">
                <h2 class="text-4xl font-light mb-4">Porozmawiajmy o projekcie.</h2>
                <p class="text-gray-400">kontakt@mantastudio.pl</p>
                <p class="text-gray-400">+48 000 000 000</p>
            </div>
            <div class="text-sm uppercase tracking-widest text-gray-500">
                <p>&copy; 2026 Manta Studio. Wszystkie prawa zastrzeżone.</p>
            </div>
        </div>
    </footer>

</body>
</html>
